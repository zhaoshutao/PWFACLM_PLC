<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.6">
  <POU Name="FB_AxisControl" Id="{c554a4a8-6590-4b9a-ab58-9c5bdd7e02a8}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_AxisControl
VAR_IN_OUT
    Axis: AXIS_REF;
    IO: ST_AxisIO;
    Cfg: ST_AxisConfig;
END_VAR
VAR
    (* Motion function blocks *)
    MC_Power: MC_Power;
    MC_MoveAbsolute: MC_MoveAbsolute;
    MC_Jog: MC_Jog;
    MC_Stop: MC_Stop;
    MC_Reset: MC_Reset;
    MC_SetPosition: MC_SetPosition;

    (* State machines *)
    mState: INT;    (* Move absolute state *)
    jState: INT;    (* Jog state *)
    sState: INT;    (* Stop state *)
    rState: INT;    (* Reset state *)
    spState: INT;   (* SetPosition state *)
    esState: INT;   (* E-Stop state *)

    (* Triggers *)
    fTrigReachLS: F_TRIG;
    rTrigEStop: R_TRIG;

    (* Timers *)
    setPosDelay: TON;

    (* Internal flags *)
    mPowerEnable: BOOL;
    mPosProtectionSet: BOOL;
    btnReachLSReset: BOOL;

    (* Shadow copies for FB parameters *)
    mMoveTargetPos: LREAL;
    mMoveTargetVel: LREAL;
    mJogDistance: LREAL;
    mJogVelocity: LREAL;
    mSetPosValue: LREAL;
	
	fTrigJogBackward: F_TRIG;
	fTrigJogForward: F_TRIG;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ============================================================
   FB_AxisControl — Axis control function block
   Encapsulates: Move, Jog, Stop, Reset, SetPosition,
                 Input protection, E-Stop, LVDT, HMI interlock
   ============================================================ *)

(* ============================================================
   Call all motion FBs every cycle
   (inputs set by state machines below)
   ============================================================ *)
MC_Power(
    Axis := Axis,
    Enable := mPowerEnable,
    Enable_Positive := IO.forwardLimit,
    Enable_Negative := IO.backwardLimit,
    Override := 100
);

MC_MoveAbsolute(
    Axis := Axis,
    Execute := (mState = 3),
    Position := mMoveTargetPos,
    Velocity := mMoveTargetVel
);

MC_Jog(
    Axis := Axis,
    JogForward := (jState = 3 AND IO.btnJogForward AND NOT IO.btnJogBackward),
    JogBackwards := (jState = 3 AND IO.btnJogBackward AND NOT IO.btnJogForward),
    Mode := MC_JOGMODE_INCHING,
    Position := mJogDistance,
    Velocity := mJogVelocity
);

MC_Stop(
    Axis := Axis,
    Execute := (sState = 3)
);

MC_Reset(
    Axis := Axis,
    Execute := (rState = 1)
);

setPosDelay.PT := T#0.1S;
setPosDelay();

MC_SetPosition(
    Axis := Axis,
    Execute := (spState = 2),
    Position := mSetPosValue
);

(* ============================================================
   Input position protection
   ============================================================ *)
IF IO.btnMove THEN
    IF Cfg.targetPosition >= Cfg.minPosition AND Cfg.targetPosition <= Cfg.maxPosition THEN
        IO.inputPositionOutOfRange := FALSE;
        GVL.Error := FALSE;
        GVL.ErrorId := 0;
        GVL.ErrorDescription := '';
    ELSE
        IO.inputPositionOutOfRange := TRUE;
        GVL.Error := TRUE;
        GVL.ErrorId := 1001;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_InputPositionOutOfRange');
        RETURN;
    END_IF
END_IF

(* ============================================================
   Running status
   ============================================================ *)
Axis.ReadStatus();
IO.moving := Axis.Status.Moving;
(*
//fTrigJogForward(CLK:=IO.btnJogForward);
IF IO.btnJogForward AND jState <> 3 THEN
    IF Cfg.currentPositionRetain + Cfg.jogStep <= Cfg.maxPosition THEN
        IO.inputPositionOutOfRange := FALSE;
        GVL.Error := FALSE;
        GVL.ErrorId := 0;
        GVL.ErrorDescription := '';
    ELSE
        IO.inputPositionOutOfRange := TRUE;
        GVL.Error := TRUE;
        GVL.ErrorId := 1002;
        GVL.ErrorDescription := CONCAT('exceed ', CONCAT(Cfg.name, '_maxPosition'));
		RETURN;
    END_IF
END_IF

//fTrigJogBackward(CLK:=IO.btnJogBackward);
IF IO.btnJogBackward AND jState <> 3 THEN
    IF Cfg.currentPositionRetain - Cfg.jogStep >= Cfg.minPosition THEN
        IO.inputPositionOutOfRange := FALSE;
        GVL.Error := FALSE;
        GVL.ErrorId := 0;
        GVL.ErrorDescription := '';
    ELSE
        IO.inputPositionOutOfRange := TRUE;
        GVL.Error := TRUE;
        GVL.ErrorId := 1003;
        GVL.ErrorDescription := CONCAT('less than ', CONCAT(Cfg.name, '_minPosition'));
		IO.btnStop:=TRUE;
		RETURN;
    END_IF
END_IF

*)

(* Error status from NC *)
IF Axis.NcToPlc.ErrorCode = 0 THEN
    IO.error := FALSE;
ELSE
    IO.error := TRUE;
    GVL.Error := TRUE;
    GVL.ErrorId := 1002;
    GVL.ErrorDescription := CONCAT(Cfg.name, '.NcToPlc.ErrorCode<>0');
END_IF

(* Move done *)
IO.moveDone := MC_MoveAbsolute.Done OR MC_Jog.Done;

(* ============================================================
   Power enable logic — on if any motion state is active
   ============================================================ *)
mPowerEnable := (mState >= 1 AND mState <> 88 AND mState <> -100)
             OR (jState >= 1 AND jState <> 88 AND jState <> -100)
             OR (sState >= 1 AND sState <> 88 AND sState <> -100);

(* ============================================================
   Position Move state machine
   ============================================================ *)
CASE mState OF
    0:
        IF NOT IO.error THEN
            mState := 1;
        ELSE
            mState := -100;
        END_IF
    1:
        IF NOT MC_Power.Status THEN
            (* power is enabled via mPowerEnable above *)
        ELSE
            mState := 2;
        END_IF
    2:
        mMoveTargetPos := Cfg.targetPosition;
        mMoveTargetVel := Cfg.targetVelocity;
        IF IO.btnMove THEN
            mState := 3;
        END_IF
    3:
        IF MC_MoveAbsolute.Done THEN
            mState := 88;
        END_IF
    88:
        IO.btnMove := FALSE;
        mState := 0;
    -100:
        IO.btnMove := FALSE;
        GVL.Error := TRUE;
        IO.error := TRUE;
        GVL.ErrorId := 1002;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_move_error');
END_CASE

(* ============================================================
   Jog state machine
   ============================================================ *)
CASE jState OF
    0:
        IF NOT IO.error THEN
            jState := 1;
        ELSE
            jState := -100;
        END_IF
    1:
        IF NOT MC_Power.Status THEN
            (* waiting for power *)
        ELSE
            jState := 2;
        END_IF
    2:
        mJogDistance := Cfg.jogStep;
        mJogVelocity := Cfg.targetVelocity;
		
		IF IO.btnJogForward AND NOT IO.btnJogBackward THEN
			IF Cfg.currentPositionRetain + Cfg.jogStep <= Cfg.maxPosition THEN
				GVL.Error := FALSE;
				GVL.ErrorId := 0;
				jState := 3;
			ELSE
				IO.btnJogForward := FALSE;          // ← 立即清按钮，防 Modbus 重写
				GVL.Error := TRUE;
				GVL.ErrorId := 1002;
				GVL.ErrorDescription := CONCAT('exceed ', CONCAT(Cfg.name, '_maxPosition'));
			END_IF
		END_IF
		
		IF IO.btnJogBackward AND NOT IO.btnJogForward THEN
			IF Cfg.currentPositionRetain - Cfg.jogStep >= Cfg.minPosition THEN
				GVL.Error := FALSE;
				GVL.ErrorId := 0;
				jState := 3;
			ELSE
				IO.btnJogBackward := FALSE;         // ← 同上
				GVL.Error := TRUE;
				GVL.ErrorId := 1003;
				GVL.ErrorDescription := CONCAT('less than ', CONCAT(Cfg.name, '_minPosition'));
			END_IF
		END_IF
	
    3:
        (* Buttons kept TRUE so MC_Jog sees them next cycle; cleared in state 88/-100 *)
        IF MC_Jog.Error THEN
            jState := -100;
        ELSIF MC_Jog.Done THEN
            jState := 88;
        END_IF
    88:
        IO.btnJogForward := FALSE;
        IO.btnJogBackward := FALSE;
        jState := 0;
    -100:
        IO.btnJogForward := FALSE;
        IO.btnJogBackward := FALSE;
        GVL.Error := TRUE;
        IO.error := TRUE;
        GVL.ErrorId := 1002;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_jog_error');
END_CASE

(* ============================================================
   Stop state machine
   ============================================================ *)
CASE sState OF
    0:
        sState := 1;
    1:
        IF NOT MC_Power.Status THEN
            (* waiting for power *)
        ELSE
            sState := 2;
        END_IF
    2:
        IF IO.btnStop THEN
            sState := 3;
        END_IF
    3:
        IF MC_Stop.Done THEN
            sState := 88;
        END_IF
    88:
        IO.btnStop := FALSE;
        sState := 0;
        (* Reset all other states on stop *)
        IO.btnMove := FALSE;
        IO.btnJogForward := FALSE;
        IO.btnJogBackward := FALSE;
        mState := 0;
        jState := 0;
    -100:
        IO.btnStop := FALSE;
        GVL.Error := TRUE;
        IO.error := TRUE;
        GVL.ErrorId := 1002;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_stop_error');
        IO.btnMove := FALSE;
        IO.btnJogForward := FALSE;
        IO.btnJogBackward := FALSE;
        mState := 0;
        jState := 0;
END_CASE

(* ============================================================
   Reset state machine
   ============================================================ *)
CASE rState OF
    0:
        IF IO.btnReset OR btnReachLSReset THEN
            rState := 1;
        END_IF
    1:
        IF MC_Reset.Done THEN
            rState := 88;
        END_IF
    88:
        rState := 0;
        IO.btnReset := FALSE;
        btnReachLSReset := FALSE;
        (* Reset all other states *)
        IO.btnMove := FALSE;
        IO.btnJogForward := FALSE;
        IO.btnJogBackward := FALSE;
        mState := 0;
        sState := 0;
        jState := 0;
END_CASE

(* ============================================================
   SetPosition state machine
   ============================================================ *)
IF IO.btnSetPosition THEN
    CASE spState OF
        0:
            IF NOT IO.moving THEN
                spState := 1;
            END_IF
        1:
            mSetPosValue := Cfg.positionSetValue;
            setPosDelay.IN := TRUE;
            spState := 2;
        2:
            IF MC_SetPosition.Done THEN
                spState := 88;
            END_IF
            IF setPosDelay.Q THEN
                spState := -100;
            END_IF
        88:
            IO.positionSetDone := TRUE;
            setPosDelay.IN := FALSE;
            spState := 0;
            IO.btnSetPosition := FALSE;
        -100:
            IO.positionSetDone := FALSE;
            setPosDelay.IN := FALSE;
            IO.btnSetPosition := FALSE;
            spState := 0;
    END_CASE
ELSE
    setPosDelay.IN := FALSE;
END_IF

IF NOT IO.btnSetPosition THEN
    IO.positionSetDone := FALSE;
END_IF
(* ============================================================
   Emergency stop handler
   ============================================================ *)
IF NOT(GVL.E_STOP AND GVL.E_STOP_rem AND GVL.Plc_EmergencyStop) THEN
    CASE esState OF
        0:
            esState := 1;
        1:
            GVL.E_STOP_led := FALSE;
            mPowerEnable := FALSE;
            IO.btnStop := TRUE;
            GVL.Error := TRUE;
            GVL.ErrorId := 101;
            GVL.ErrorDescription := 'E_STOP';
    END_CASE
END_IF

rTrigEStop(CLK := GVL.E_STOP AND GVL.E_STOP_rem AND GVL.Plc_EmergencyStop);
IF rTrigEStop.Q THEN
    GVL.E_STOP_led := TRUE;
    GVL.Error := FALSE;
    GVL.ErrorId := 0;
    GVL.ErrorDescription := '';
    esState := 0;
END_IF

(* ============================================================
   Limit switch auto-reset (both limits hit -> trigger reset)
   ============================================================ *)
IO.touchLimitSwitch := IO.forwardLimit AND IO.backwardLimit;

fTrigReachLS(CLK := IO.forwardLimit AND IO.backwardLimit);
IF fTrigReachLS.Q THEN
    IO.btnReset := TRUE;
    btnReachLSReset := TRUE;
END_IF

(* ============================================================
   LVDT sensor processing
   ============================================================ *)
//raw data convert mA
IO.lvdtmA:=(INT_TO_REAL(IO.lvdtRaw)/32767)*16+4;
//mA convert to actual position:4-20mA → -10~40mm
IO.lvdtPV:= ((IO.lvdtmA-4.0)/16.0)*50.0-10;

IF Cfg.lvdtFunctionOn THEN
    IF IO.lvdtPV <= Cfg.lvdtThreshold THEN
        IO.lvdtOutOfThreshold := FALSE;
        GVL.Error := TRUE;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_LVDT In Alarm Range');
        IO.lvdtOnceInRangeFlag := 1;
    END_IF
    IF IO.lvdtOnceInRangeFlag = 1 THEN
        IO.lvdtOutOfThreshold := FALSE;
        GVL.Error := TRUE;
        GVL.ErrorDescription := CONCAT(Cfg.name, '_LVDT In Alarm Range');
        IF Cfg.lvdtManualReleaseAlarm THEN
            GVL.Error := FALSE;
            GVL.ErrorDescription := '';
            IO.lvdtOnceInRangeFlag := 0;
            Cfg.lvdtManualReleaseAlarm := FALSE;
            IO.lvdtOutOfThreshold := TRUE;
        END_IF
    END_IF
END_IF

(* ============================================================
   HMI button interlock logic (Local mode only)
   ============================================================ *)
(* JOG+ enabled? *)
IF IO.forwardLimit AND GVL.E_STOP AND GVL.Local_led AND NOT IO.error
   AND NOT IO.moving AND NOT IO.btnMove AND NOT IO.btnJogBackward THEN
    IO.btnJogFwdEnabled := TRUE;
ELSE
    IO.btnJogFwdEnabled := FALSE;
END_IF

(* JOG- enabled? *)
IF IO.backwardLimit AND GVL.E_STOP AND GVL.Local_led AND NOT IO.error
   AND NOT IO.moving AND NOT IO.btnMove AND NOT IO.btnJogForward THEN
    IO.btnJogBwdEnabled := TRUE;
ELSE
    IO.btnJogBwdEnabled := FALSE;
END_IF

(* Position Move enabled? *)
IF GVL.E_STOP AND GVL.Local_led AND NOT IO.error AND NOT IO.moving
   AND NOT IO.btnJogForward AND NOT IO.btnJogBackward THEN
    IO.btnMoveEnabled := TRUE;
ELSE
    IO.btnMoveEnabled := FALSE;
END_IF

(* SetPosition enabled? *)
IF GVL.E_STOP AND GVL.Local_led AND NOT IO.error AND NOT IO.moving THEN
    IO.btnSetPosEnabled := TRUE;
ELSE
    IO.btnSetPosEnabled := FALSE;
END_IF

(* Stop enabled? *)
IF GVL.E_STOP AND GVL.Local_led AND NOT IO.error THEN
    IO.btnStopEnabled := TRUE;
ELSE
    IO.btnStopEnabled := FALSE;
END_IF]]></ST>
    </Implementation>
